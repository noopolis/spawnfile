{
  "agents": {
    "defaults": {
      "workspace": "<workspace-path>"
    }
  },
  "tools": {
    "profile": "coding"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "<generated-at-setup>"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  }
}

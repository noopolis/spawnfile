<script>
const runtimes = [
  { name: 'openclaw', label: 'Compiled for OpenClaw' },
  { name: 'picoclaw', label: 'Compiled for PicoClaw' },
  { name: 'tinyclaw', label: 'Compiled for TinyClaw' },
  { name: 'nullclaw', label: 'Compiled for NullClaw' },
  { name: 'zeroclaw', label: 'Compiled for ZeroClaw' }
];

let current = 0;
let autoTimer = null;
const srcRuntime = document.getElementById('src-runtime');
const bundleLabel = document.getElementById('bundle-label');
const bundleFiles = document.querySelectorAll('.bundle-file');
const bundleRun = document.querySelector('.bundle-run');
const pills = document.querySelectorAll('.runtime-pill-btn');
const cmd = document.querySelector('.proof-cmd');

function typewrite(el, text) {
  el.textContent = '';
  el.style.borderRight = '2px solid var(--coral)';
  let i = 0;
  function tick() {
    if (i <= text.length) {
      el.textContent = text.slice(0, i);
      i++;
      setTimeout(tick, 40);
    } else {
      setTimeout(() => { el.style.borderRight = 'none'; }, 300);
    }
  }
  tick();
}

function revealBundle() {
  bundleFiles.forEach((f, i) => {
    f.style.opacity = '0';
    f.style.transform = 'translateY(6px)';
    setTimeout(() => {
      f.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
      f.style.opacity = '1';
      f.style.transform = 'translateY(0)';
    }, i * 100);
  });
  bundleRun.style.opacity = '0';
  bundleRun.style.transform = 'translateY(6px)';
  setTimeout(() => {
    bundleRun.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
    bundleRun.style.opacity = '1';
    bundleRun.style.transform = 'translateY(0)';
  }, bundleFiles.length * 100);
}

function spinCompile() {
  cmd.classList.remove('compiling');
  void cmd.offsetWidth;
  cmd.classList.add('compiling');
  setTimeout(() => cmd.classList.remove('compiling'), 1100);
}

function setRuntime(idx, animate) {
  current = idx;
  const rt = runtimes[idx];
  pills.forEach((p, i) => p.classList.toggle('active', i === idx));

  if (animate) {
    typewrite(srcRuntime, rt.name);
    spinCompile();
    setTimeout(() => {
      bundleLabel.textContent = rt.label;
      revealBundle();
    }, 200);
  } else {
    srcRuntime.textContent = rt.name;
    bundleLabel.textContent = rt.label;
  }
}

document.getElementById('runtime-pills').addEventListener('click', (e) => {
  const pill = e.target.closest('.runtime-pill-btn');
  if (pill) {
    e.preventDefault();
    const idx = pill.dataset.idx;
    if (idx !== undefined) {
      if (autoTimer) clearTimeout(autoTimer);
      setRuntime(parseInt(idx), true);
      setTimeout(() => startLoop(parseInt(idx)), 4500);
    }
  }
});

function startLoop(startIdx) {
  let idx = startIdx;
  function step() {
    idx = (idx + 1) % runtimes.length;
    setRuntime(idx, true);
    autoTimer = setTimeout(step, 2400);
  }
  autoTimer = setTimeout(step, 2400);
}

setTimeout(() => startLoop(0), 1500);
</script>

<!-- HOW IT WORKS -->
<section class="section section-border" id="how">
  <p class="section-kicker">How it works</p>
  <h2>Write it once. <em>Compile for the target runtime.</em></h2>
  <p class="section-desc">Start with one Spawnfile and a few markdown docs. The compiler generates the config and workspace files each runtime expects. Optionally package it all in a Docker container.</p>

  <div class="steps">
    <div class="step">
      <h3>Describe the agent</h3>
      <p>One config file points to the markdown docs and skills your agent needs.</p>
      <pre><span class="k">kind:</span> agent
<span class="k">name:</span> research-assistant
<span class="k">runtime:</span> openclaw

<span class="k">docs:</span>
  <span class="k">soul:</span> SOUL.md
  <span class="k">identity:</span> IDENTITY.md
  <span class="k">system:</span> AGENTS.md

<span class="k">skills:</span>
  - <span class="k">ref:</span> ./skills/web_search</pre>
    </div>

    <div class="step">
      <h3>Compile the runtime files</h3>
      <p>Spawnfile generates the config file and workspace docs that the target runtime expects.</p>
      <pre><span class="cmd">$ spawnfile compile</span>

Compiling for <span class="k">openclaw</span>
Writing openclaw.json     <span class="ok">done</span>
Writing workspace docs    <span class="ok">done</span>

<span class="ok">&#10003;</span> <span class="cmd">dist/runtimes/openclaw/</span></pre>
    </div>

    <div class="step">
      <h3>Package (optional Docker)</h3>
      <p>Package the compiled output into a Docker container, or just copy the files to your runtime directly.</p>
      <pre><span class="cmd">$ spawnfile build</span>

Generating Dockerfile     <span class="ok">done</span>
Building image            <span class="ok">done</span>

<span class="ok">&#10003;</span> <span class="cmd">research-assistant:latest</span>

<span class="cmd">$ docker run -p 18789:18789 \
    research-assistant</span>

<span class="k">&#9679;</span> <span class="cmd">Agent live</span>
  model: claude-sonnet-4-5</pre>
    </div>
  </div>
</section>


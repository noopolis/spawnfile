<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #0b0b0b;
  --surface: #111;
  --ink: #f3eee7;
  --sub: #d1c7b8;
  --mute: #a59d94;
  --faint: #6b6560;
  --coral: #d4604a;
  --coral-hi: #ff8a72;
  --cyan: #00E5CC;
  --border: rgba(255,255,255,0.07);
}

html { scroll-behavior: smooth; overflow-x: hidden; }

body {
  font-family: 'DM Sans', system-ui, sans-serif;
  background: var(--bg);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
}

/* GitHub corner */
.github-corner {
  position: fixed;
  top: 0;
  right: 0;
  z-index: 150;
  line-height: 0;
  color: var(--bg);
}
.github-corner svg { display: block; }
.github-corner .octo-arm { transform-origin: 130px 106px; }
.github-corner:hover .octo-arm {
  animation: octo-wave 0.56s ease-in-out;
}
@keyframes octo-wave {
  0%, 100% { transform: rotate(0); }
  20%, 60% { transform: rotate(-26deg); }
  40%, 80% { transform: rotate(12deg); }
}

/* === NAV === */
.nav {
  position: fixed; top: 0; width: 100%; z-index: 100;
  background: rgba(11,11,11,0.85);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
}
.nav-in {
  max-width: 1200px; margin: 0 auto;
  padding: 0.7rem 2.5rem;
  display: flex; align-items: center; justify-content: space-between;
}
.mark {
  font-family: 'JetBrains Mono', monospace;
  font-weight: 700;
  font-size: 0.92rem;
  text-decoration: none;
  line-height: 1;
  background: linear-gradient(90deg, var(--ink) 0%, var(--ink) 55.5%, var(--coral) 55.5%, var(--coral) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.nav-links { display: flex; gap: 1.5rem; margin-right: 3rem; }
.nav-links a { font-size: 0.78rem; font-weight: 500; color: var(--mute); text-decoration: none; }
.nav-links a:hover { color: var(--ink); }

/* === HERO === */
.hero {
  max-width: 1200px; margin: 0 auto;
  padding: 5.5rem 2.5rem 4rem;
  position: relative;
  overflow: visible;
}

/* Atmospheric glow */
.hero::before {
  content: '';
  position: absolute;
  top: -10%;
  left: 50%;
  transform: translateX(-50%);
  width: 100vw;
  height: 600px;
  background:
    radial-gradient(ellipse 60% 70% at 30% 30%, rgba(212,96,74,0.18), transparent),
    radial-gradient(ellipse 50% 60% at 75% 35%, rgba(212,96,74,0.08), transparent);
  pointer-events: none;
}

.hero > * { position: relative; z-index: 1; }

br.mobile-break { display: none; }

.btn-ghost {
  background: transparent;
  border-color: transparent;
  color: var(--mute);
  padding: 0.5rem 0;
}
.btn-ghost:hover { color: var(--ink); background: transparent; border-color: transparent; }

.hero-top {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: center;
  margin-bottom: 1rem;
}

.hero-illustration {
  width: 120%;
  max-width: 820px;
  justify-self: end;
}

.hero-eyebrow {
  font-family: 'JetBrains Mono';
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--coral);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}

.hero h1 {
  font-family: 'Instrument Serif', serif;
  font-size: clamp(2.8rem, 4.5vw, 4.2rem);
  font-weight: 400;
  line-height: 0.92;
  letter-spacing: -0.04em;
  margin-bottom: 1.2rem;
  max-width: 20ch;
}

.hero h1 em {
  font-style: italic;
  color: var(--coral);
}

.hero-sub {
  font-size: 1rem;
  font-weight: 400;
  color: var(--sub);
  line-height: 1.6;
  max-width: 42ch;
  margin-bottom: 1.25rem;
}

.hero-actions {
  display: flex; gap: 0.7rem; align-items: center;
  margin-bottom: 1rem;
}

.btn {
  font-family: 'DM Sans'; font-weight: 600; font-size: 0.88rem;
  padding: 0.7rem 1.4rem; border-radius: 8px; text-decoration: none;
  border: 1px solid var(--border); color: var(--ink); background: var(--surface);
  transition: all 0.15s;
}
.btn:hover { border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.05); }
.btn-fill { background: var(--coral); color: #fff; border-color: var(--coral); box-shadow: 0 12px 32px rgba(212,96,74,0.25); }
.btn-fill:hover { background: #c0543f; }

/* === THE PROOF === */
.proof {
  position: relative;
  border: 1px solid var(--border);
  border-radius: 20px;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.02), transparent 30%),
    var(--surface);
  box-shadow: 0 40px 80px rgba(0,0,0,0.4);
}

.proof-row {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  min-height: 280px;
}

.proof-source {
  padding: 1.5rem 2rem;
  border-right: 1px solid var(--border);
}

.proof-label {
  font-family: 'JetBrains Mono';
  font-size: 0.65rem;
  font-weight: 600;
  color: var(--mute);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.proof-source pre {
  font-family: 'JetBrains Mono';
  font-size: 0.88rem;
  line-height: 1.7;
  color: var(--ink);
}

.proof-source .k { color: var(--coral); }
.proof-source .v { color: var(--sub); }

.runtime-animated {
  color: var(--coral);
  font-weight: 700;
  display: inline;
  padding-right: 2px;
  transition: opacity 0.3s;
}

.proof-runtime-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
  margin-top: 1rem;
  padding-top: 0.75rem;
  border-top: 1px solid var(--border);
}

.runtime-pill-btn {
  font-family: 'JetBrains Mono';
  font-size: 0.65rem;
  padding: 0.22rem 0.5rem;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,0.02);
  color: var(--faint);
  cursor: pointer;
  transition: all 0.4s ease;
  text-decoration: none;
}

.runtime-pill-btn:hover {
  color: var(--sub);
  border-color: rgba(255,255,255,0.12);
}

.runtime-pill-btn.active {
  color: var(--ink);
  border-color: var(--coral);
  background: rgba(212,96,74,0.1);
}

.bundle-file, .bundle-run {
  transition: opacity 0.3s, transform 0.3s;
}

/* Compile shimmer */
.proof-cmd {
  position: relative;
  overflow: hidden;
  font-family: 'JetBrains Mono';
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--ink);
  background: var(--surface);
  border: 2px solid var(--border);
  border-radius: 6px;
  white-space: nowrap;
  padding: 0.45rem 0.75rem;
}

.proof-cmd::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(212,96,74,0.2), rgba(212,96,74,0.1), transparent);
  pointer-events: none;
}

.proof-cmd.compiling::after {
  animation: shimmer-slide 1s ease-in-out;
}

@keyframes shimmer-slide {
  0% { left: -60%; }
  100% { left: 120%; }
}

.cmd-prefix { color: var(--coral); }

/* Arrow / Command */
.proof-arrow {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 0.75rem;
  gap: 0.5rem;
}

/* Output side */
.proof-output {
  padding: 1.5rem 2rem;
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 0;
  justify-content: center;
}

.bundle-files {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  margin-bottom: 0.75rem;
}

.bundle-file {
  font-family: 'JetBrains Mono';
  font-size: 0.78rem;
  color: var(--sub);
  padding: 0.2rem 0;
}

.bundle-icon {
  color: var(--coral);
  margin-right: 0.4rem;
  font-size: 0.7rem;
}

.bundle-check {
  color: var(--cyan);
  margin-right: 0.35rem;
  font-size: 0.72rem;
}

.bundle-run {
  padding: 0.6rem 0.8rem;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: rgba(255,255,255,0.015);
  margin-bottom: 0.5rem;
}

.bundle-run-label {
  font-family: 'JetBrains Mono';
  font-size: 0.58rem;
  font-weight: 600;
  color: var(--mute);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 0.35rem;
}

.bundle-run-item {
  font-family: 'JetBrains Mono';
  font-size: 0.72rem;
  color: var(--cyan);
  padding: 0.1rem 0;
}

/* Bottom bar */
.proof-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 2rem;
  border-top: 1px solid var(--border);
  background: rgba(255,255,255,0.015);
}

.proof-bar-left {
  display: flex; gap: 1rem; align-items: center;
  font-family: 'JetBrains Mono';
  font-size: 0.72rem;
  color: var(--mute);
}

.proof-bar-left .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--cyan); margin-right: 0.4rem; }

.proof-bar-right {
  font-family: 'JetBrains Mono';
  font-size: 0.68rem;
  color: var(--faint);
}

/* === SECTIONS === */
.section {
  max-width: 1200px; margin: 0 auto;
  padding: 7rem 2.5rem;
}

.section-border { border-top: 1px solid var(--border); }

.section-kicker {
  font-family: 'JetBrains Mono';
  font-size: 0.68rem;
  color: var(--coral);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 1rem;
}

.section h2 {
  font-family: 'Instrument Serif', serif;
  font-size: clamp(2.2rem, 4vw, 3.5rem);
  font-weight: 400;
  line-height: 0.95;
  letter-spacing: -0.03em;
  margin-bottom: 0.75rem;
}

.section h2 em { font-style: italic; color: var(--coral); }

.section-desc {
  font-size: 1rem;
  color: var(--sub);
  max-width: 48ch;
  line-height: 1.6;
  margin-bottom: 3rem;
}

/* === HOW IT WORKS === */
.steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  counter-reset: step;
}

.step {
  position: relative;
  padding: 1.5rem;
  min-width: 0;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent 40%), var(--surface);
  counter-increment: step;
}

.step::before {
  content: counter(step, decimal-leading-zero);
  position: absolute;
  top: 1rem; right: 1.25rem;
  font-family: 'Instrument Serif';
  font-size: 3.5rem;
  color: rgba(255,255,255,0.03);
  line-height: 1;
}

.step:nth-child(2) {
  border-color: rgba(212,96,74,0.25);
  box-shadow: 0 0 0 1px rgba(212,96,74,0.06), 0 24px 60px rgba(212,96,74,0.08);
}

.step h3 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.4rem;
}

.step p {
  font-size: 0.85rem;
  color: var(--mute);
  line-height: 1.5;
  margin-bottom: 1rem;
}

.step pre {
  font-family: 'JetBrains Mono';
  font-size: 0.78rem;
  line-height: 1.65;
  color: var(--sub);
  padding: 0.9rem;
  background: rgba(0,0,0,0.3);
  border: 1px solid var(--border);
  border-radius: 10px;
}

.step pre .k { color: var(--coral); }
.step pre .ok { color: var(--cyan); }
.step pre .cmd { color: var(--ink); font-weight: 700; }

/* === TEAMS === */
.org {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  position: relative;
  padding: 3rem 2rem;
  border: 1px solid var(--border);
  border-radius: 24px;
  background:
    radial-gradient(circle at 50% 0%, rgba(212,96,74,0.08), transparent 40%),
    var(--surface);
}

.org::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 48px 48px;
  mask-image: linear-gradient(180deg, rgba(0,0,0,0.5), transparent);
  -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.5), transparent);
  pointer-events: none;
  border-radius: 24px;
}

.org > * { position: relative; z-index: 1; }

.org-chart-svg {
  width: 100%;
  height: auto;
  max-width: 520px;
}

.team-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
}

.team-code {
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
}

.team-code-bar {
  padding: 0.5rem 1rem;
  border-bottom: 1px solid var(--border);
}

.team-code pre {
  padding: 1.25rem;
  font-family: 'JetBrains Mono';
  font-size: 0.78rem;
  line-height: 1.65;
  color: var(--ink);
  flex: 1;
}

.team-code .k { color: var(--coral); }
.team-code .v { color: var(--sub); }

.team-split .org {
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 2rem 1.5rem;
}

.team-split .org::before {
  border-radius: 0;
}

.org-external {
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.org-ext-label {
  font-family: 'JetBrains Mono';
  font-size: 0.6rem;
  color: var(--mute);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.org-ext-channels {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
  justify-content: center;
}

.org-ext-chip {
  font-family: 'JetBrains Mono';
  font-size: 0.68rem;
  font-weight: 500;
  padding: 0.25rem 0.6rem;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,0.02);
  color: var(--sub);
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
}

.org-ext-note {
  font-size: 0.75rem;
  color: var(--faint);
  max-width: 48ch;
  text-align: center;
  line-height: 1.5;
  margin-top: 0.25rem;
}

.org-caption {
  margin-top: 2rem;
  font-family: 'JetBrains Mono';
  font-size: 0.68rem;
  color: var(--mute);
  text-align: center;
  padding: 0.5rem 1rem;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255,255,255,0.02);
}

/* === PLATFORMS === */
.platforms {
  display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap;
  position: relative; padding: 0.5rem 0;
}

.platforms::before {
  content: '';
  position: absolute;
  left: 10%; right: 10%; top: 50%;
  height: 1px;
  background: linear-gradient(90deg, rgba(212,96,74,0.2), rgba(212,96,74,0.15));
}

.plat {
  position: relative; z-index: 1;
  display: flex; align-items: center; gap: 0.5rem;
  padding: 0.5rem 1rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 999px;
  font-family: 'JetBrains Mono';
  font-size: 0.8rem;
  font-weight: 500;
  box-shadow: 0 8px 20px rgba(0,0,0,0.2);
  text-decoration: none;
  color: var(--ink);
  transition: border-color 0.2s;
}
.plat:hover { border-color: var(--coral); }

.plat-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--cyan); }

/* === CTA === */
.cta-section {
  max-width: 1200px; margin: 0 auto;
  padding: 6rem 2.5rem;
  text-align: center;
  border-top: 1px solid var(--border);
}

.cta-section h2 {
  font-family: 'Instrument Serif';
  font-size: clamp(2.5rem, 4.5vw, 4rem);
  font-weight: 400;
  font-style: italic;
  margin-bottom: 0.5rem;
}

.cta-section h2 em { color: var(--coral); }
.cta-section p { color: var(--faint); margin-bottom: 2rem; font-size: 1rem; }
.cta-btns { display: flex; gap: 0.7rem; justify-content: center; }

/* === FOOTER === */
footer {
  max-width: 1200px; margin: 0 auto;
  padding: 1.5rem 2.5rem;
  display: flex; justify-content: space-between;
  font-size: 0.72rem; color: var(--faint);
  border-top: 1px solid var(--border);
}
footer a { color: var(--faint); text-decoration: none; }
footer a:hover { color: var(--sub); }

/* === RESPONSIVE === */
@media (max-width: 900px) {
  .hero-illustration { display: none; }
  .proof-runtime-pills { display: none; }
  .proof-bar { display: none; }

  .proof { border-radius: 12px; }
  .proof-row { gap: 0; }
  .proof-source { padding: 1rem 1.25rem; border-bottom: none; }
  .proof-source pre { font-size: 0.82rem; }

  .proof-arrow {
    padding: 0.4rem 1.25rem;
    align-items: flex-start;
    justify-content: flex-start;
    background: rgba(255,255,255,0.015);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .proof-cmd {
    font-size: 0.78rem;
    border: none;
    background: transparent;
    padding: 0.3rem 0;
  }

  .proof-output {
    padding: 0.75rem 1.25rem;
    gap: 0.3rem;
  }
  .proof-label { margin-bottom: 0.3rem; }

  .proof-output > div:nth-child(3),
  .proof-output > div:nth-child(4),
  .proof-output > div:nth-child(5) { display: none; }
  .hero-top { grid-template-columns: 1fr; }

  .nav-links { display: none; }
  .nav-in { padding: 0.6rem 1.25rem; }


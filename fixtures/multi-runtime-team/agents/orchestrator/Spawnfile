spawnfile_version: "0.1"
kind: agent
name: orchestrator
description: "Coordinates the research team, assigns tasks, and synthesizes findings"

runtime: openclaw

execution:
  model:
    primary:
      provider: anthropic
      name: claude-sonnet-4-5
      auth:
        method: claude-code
  workspace:
    isolation: isolated
  sandbox:
    mode: workspace

surfaces:
  http:
    access:
      mode: open

docs:
  system: AGENTS.md

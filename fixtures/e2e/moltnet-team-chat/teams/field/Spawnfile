spawnfile_version: "0.1"
kind: team
name: field-team
description: "Child team with an explicit representative and a local Moltnet room"

shared:
  workspace:
    docs:
      system: TEAM.md

members:
  - id: field-representative
    ref: ./agents/representative
  - id: field-observer
    ref: ./agents/observer

mode: hierarchical
lead: field-representative
external: [field-representative]

networks:
  - id: field_lab
    name: Field Lab
    provider: moltnet
    server:
      mode: managed
      listen:
        bind: 127.0.0.1
        port: 8787
      store:
        kind: memory
      auth:
        mode: none
      human_ingress: true
    rooms:
      - id: field-room
        members: [field-representative, field-observer]

policy:
  mode: warn
  on_degrade: warn

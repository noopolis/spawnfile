spawnfile_version: "0.1"
kind: team
name: moltnet-team-chat
description: "E2E fixture for Moltnet representative team chat"

shared:
  workspace:
    docs:
      system: TEAM.md

members:
  - id: coordinator
    ref: ./agents/coordinator
  - id: field-team
    ref: ./teams/field
  - id: analysis-team
    ref: ./teams/analysis

mode: hierarchical
lead: coordinator
external: [coordinator]

networks:
  - id: local_lab
    name: Local Lab
    provider: moltnet
    server:
      mode: managed
      listen:
        bind: 0.0.0.0
        port: 8787
      store:
        kind: memory
      auth:
        mode: none
      human_ingress: true
    rooms:
      - id: mission-control
        members: [coordinator, field-team, analysis-team]

policy:
  mode: warn
  on_degrade: warn

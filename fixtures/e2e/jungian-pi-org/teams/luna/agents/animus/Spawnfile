spawnfile_version: "0.1"
kind: agent
name: luna-animus
description: "Luna inner archetype (Antigravity CLI engine)"

runtime:
  name: pi
  options:
    engine: agy

execution:
  model:
    primary:
      provider: local
      name: agy-cli
      auth:
        method: none
      endpoint:
        compatibility: openai
        base_url: http://127.0.0.1:11434/v1
  sandbox:
    mode: workspace

surfaces:
  moltnet:
    - network: luna_inner
      rooms:
        luna-council:
          wake: mentions

workspace:
  docs:
    system: AGENTS.md

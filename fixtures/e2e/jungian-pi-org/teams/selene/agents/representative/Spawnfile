spawnfile_version: "0.1"
kind: agent
name: selene-representative
description: "Selene representative (Grok CLI engine)"

runtime:
  name: pi
  options:
    engine: grok

execution:
  model:
    primary:
      provider: local
      name: grok-dual
      auth:
        method: none
      endpoint:
        compatibility: openai
        base_url: http://127.0.0.1:11434/v1
  sandbox:
    mode: workspace

surfaces:
  moltnet:
    - network: selene_inner
      rooms:
        selene-council:
          wake: mentions

workspace:
  docs:
    system: AGENTS.md
